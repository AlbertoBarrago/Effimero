# Copy to .env. Leave empty to auto-generate a key at every server start.
# Set a strong value here to keep dashboard/API access stable across restarts.
STATS_API_KEY=

# Set true when Effimero runs behind nginx, Caddy, Traefik, or another proxy.
TRUST_PROXY=false

# Comma-separated origins allowed to POST hits. Use concrete site origins in production.
ALLOWED_ORIGINS=*

# Days of aggregate daily stats kept in Redis.
RETENTION_DAYS=90

# Max /collect hits per client IP per window (seconds). Set the limit to 0 to disable.
COLLECT_RATE_LIMIT=120
COLLECT_RATE_WINDOW=60

# Max distinct paths/referrers tracked per site per day; extras fold into "__other__".
MAX_DISTINCT_PATHS=2000
MAX_DISTINCT_REFERRERS=2000
